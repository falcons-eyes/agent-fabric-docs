[8.1596, "o", "\u001b[1;38;5;63mfabric doctor\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m config         \u001b[38;5;241m~/.fabric/config.json \u00b7 control http://127.0.0.1:18090\u001b[0m\r\n\u001b[1;38;5;214m\u26a0\u001b[0m session        \u001b[38;5;241mlogged in \u00b7 token in PLAINTEXT config (set AF_KEYSTORE_PASSPHRASE)\u001b[0m\r\n\u001b[38;5;241m                \u2192 set AF_KEYSTORE_PASSPHRASE to encrypt the token at rest\u001b[0m\r\n\u001b[1;38;5;214m\u26a0\u001b[0m keystore       \u001b[38;5;241mnone \u2014 client secrets in plaintext config (set AF_KEYSTORE_PASSPHRASE)\u001b[0m\r\n\u001b[38;5;241m                \u2192 set AF_KEYSTORE_PASSPHRASE\u001b[0m\r\n\u001b[1;38;5;214m\u26a0\u001b[0m wireguard      \u001b[38;5;241mwg not found \u2014 install wireguard-tools (Debian/Ubuntu: sudo apt install wireguard-tools)\u001b[0m\r\n\u001b[38;5;241m                \u2192 install wireguard-tools (Debian/Ubuntu: sudo apt install wireguard-tools)\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m control plane  \u001b[38;5;241mreachable \u00b7 healthz 601ms\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m control key    \u001b[38;5;241mpinned 75762637ad0df9c9 \u00b7 matches server\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m node           \u001b[38;5;241mdemo-laptop (fdfd:4afb:fda0::1) \u00b7 key in plaintext config\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m entitlement    \u001b[38;5;241mpro \u00b7 active \u00b7 lease 24h0m0s left\u001b[0m\r\n\u001b[1;38;5;214m\u26a0\u001b[0m tunnel         \u001b[38;5;241mnot running \u2014 run `fabric up` to connect\u001b[0m\r\n\u001b[38;5;241m                \u2192 fabric up\u001b[0m\r\n\r\n\u001b[1;38;5;214m\u26a0\u001b[0m overall        \u001b[38;5;241m4 warning(s)\u001b[0m\r\n"]
