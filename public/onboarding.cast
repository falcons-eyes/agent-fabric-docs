[13.4503, "o", "\u001b[1;38;5;63mfalcon status\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m node           \u001b[38;5;241mdemo-laptop (fd53:74d4:1681::1)\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m control plane  \u001b[38;5;241mreachable \u00b7 healthz 601ms\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m entitlement    \u001b[38;5;241mfree \u00b7 active \u00b7 lease 24h0m0s left\u001b[0m\r\n\u001b[1;38;5;214m\u26a0\u001b[0m tunnel         \u001b[38;5;241mnot running \u2014 run `falcon up` to connect\u001b[0m\r\n\u001b[38;5;241m                \u2192 falcon up\u001b[0m\r\n\u001b[1;38;5;42m\u2714\u001b[0m relay          \u001b[38;5;241mno relay configured (direct-only)\u001b[0m\r\n\u001b[1;38;5;63mservices\u001b[0m\r\n  \u001b[1;38;5;63mNAME         \u001b[0m  \u001b[1;38;5;63mKIND\u001b[0m  \u001b[1;38;5;63mADDR                     \u001b[0m\r\n  \u001b[38;5;252mollama-native\u001b[0m  \u001b[38;5;252mllm \u001b[0m  \u001b[38;5;252mhttp://127.0.0.1:11434/v1\u001b[0m\r\n\r\n\u001b[1;38;5;214m\u26a0\u001b[0m overall        \u001b[38;5;241m1 warning(s)\u001b[0m\r\n"]
