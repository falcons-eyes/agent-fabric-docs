[6.7429, "o", "\u001b[4A\n\n\n\u001b[1;38;5;42m\u2714\u001b[0m published \"ollama-native\" \u2014 reachable privately, no public port\u001b[K\r\n\r\u001b[2K\r\u001b[?2004l\u001b[?25h\u001b[?1002l\u001b[?1003l\u001b[?1006l\r\n\u001b[1;38;5;63mproving it works\u001b[0m\r\n"]
[7.3854, "o", "\u001b[1;38;5;42m\u2714\u001b[0m minted a capability \u2014 llm://ollama-native, action=invoke, expires in 10m (revoke any time)\r\n"]
[8.0274, "o", "\u001b[1;38;5;42m\u2714\u001b[0m gateway authorized \u2192 ollama-native on \"demo-laptop\"\r\n"]
[8.6693, "o", "\u001b[1;38;5;42m\u2714\u001b[0m without that token: refused \u2014 ollama-native is unreachable to anyone you haven't granted\r\n\u001b[?25l\u001b[?2004h"]
[8.671, "o", "\r\u001b[38;5;39m\u28fd \u001b[0m calling your model through the authorized address\u2026\u001b[K\r\u001b[2K\r\u001b[?2004l\u001b[?25h\u001b[?1002l\u001b[?1003l\u001b[?1006l\u001b[38;5;241m  reachable \u2014 the model is still warming up; run \u001b[0m\u001b[38;5;80mfalcon try ollama-native\u001b[0m\u001b[38;5;241m again to see it answer.\u001b[0m\r\n\r\n\u001b[1;38;5;63mwhat changed\u001b[0m\r\n\u001b[38;5;241m  before   your model ran on one machine, reachable only from localhost\u001b[0m\r\n\u001b[38;5;241m  now      a private service your team reaches only with a token you mint \u2014 encrypted, no public port, revocable\u001b[0m\r\n  \u001b[38;5;245mgive a teammate access:\u001b[0m \u001b[38;5;80mfalcon grant llm://ollama-native --action invoke\u001b[0m\r\n\r\n\u001b[1;38;5;63mnext\u001b[0m\r\n\u001b[38;5;241m  \u2022 This machine joined a private, encrypted mesh \u2014 no ports opened, no networking to configure.\u001b[0m\r\n  \u001b[38;5;245mroute traffic between machines:\u001b[0m \u001b[38;5;80msudo -E falcon up\u001b[0m\r\n  \u001b[38;5;245mprove it again anytime:\u001b[0m \u001b[38;5;80mfalcon try ollama-native\u001b[0m\r\n  \u001b[38;5;245msee the mesh:\u001b[0m \u001b[38;5;80mfalcon status  \u00b7  falcon ping <peer>\u001b[0m\r\n"]
