---
// A tabbed browser window playing real screen recordings of the Cloud Console and
// Local Console (Playwright captures against a seeded demo control plane — dummy
// data only). Same tab pattern as the CLI terminal demos; a browser chrome (traffic
// lights + address bar) frames the video instead of a terminal.
//
// Props: demos = [{ label, src, url, caption }]
const { demos } = Astro.props;
---

<div class="fe-consoles">
  <div class="fe-consoles__tabs" role="tablist" aria-label="console demos">
    {
      demos.map((d, i) => (
        <button class="fe-consoles__tab" role="tab" type="button" data-i={i} aria-selected={i === 0 ? 'true' : 'false'}>
          {d.label}
        </button>
      ))
    }
  </div>

  <figure class="fe-browser">
    <div class="fe-browser__frame">
      <div class="fe-browser__chrome">
        <span class="fe-browser__dot fe-browser__dot--r"></span>
        <span class="fe-browser__dot fe-browser__dot--y"></span>
        <span class="fe-browser__dot fe-browser__dot--g"></span>
        <span class="fe-browser__addr" id="fe-consoles-url">{demos[0].url}</span>
      </div>
      <video
        id="fe-consoles-video"
        src={demos[0].src}
        autoplay
        muted
        loop
        playsinline
        aria-label="console demo recording"></video>
    </div>
    <figcaption class="fe-browser__caption" id="fe-consoles-cap">{demos[0].caption}</figcaption>
  </figure>

  <script type="application/json" id="fe-consoles-data" set:html={JSON.stringify(demos)} />
</div>

<script>
  function initConsoles() {
    const dataEl = document.getElementById('fe-consoles-data');
    const video = document.getElementById('fe-consoles-video');
    if (!dataEl || !video || video.dataset.mounted) return;
    video.dataset.mounted = '1';
    const demos = JSON.parse(dataEl.textContent || '[]');
    const url = document.getElementById('fe-consoles-url');
    const cap = document.getElementById('fe-consoles-cap');
    const tabs = Array.from(document.querySelectorAll('.fe-consoles__tab'));
    tabs.forEach((t, i) =>
      t.addEventListener('click', () => {
        video.src = demos[i].src;
        video.play().catch(() => {});
        if (url) url.textContent = demos[i].url;
        if (cap) cap.textContent = demos[i].caption;
        tabs.forEach((x, j) => x.setAttribute('aria-selected', j === i ? 'true' : 'false'));
      })
    );
  }
  document.addEventListener('DOMContentLoaded', initConsoles);
  document.addEventListener('astro:page-load', initConsoles);
  initConsoles();
</script>

<style>
  .fe-consoles {
    max-width: 880px;
    margin: 2.5rem auto 1.5rem;
  }
  .fe-consoles__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
    justify-content: center;
  }
  .fe-consoles__tab {
    font: inherit;
    font-size: 0.82rem;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-5, #2a3f52);
    background: var(--sl-color-gray-6, #f3f6f9);
    color: var(--sl-color-text, inherit);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .fe-consoles__tab:hover {
    border-color: var(--sl-color-accent);
  }
  .fe-consoles__tab[aria-selected='true'] {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: #fff;
    font-weight: 600;
  }

  .fe-browser {
    margin: 0;
  }
  .fe-browser__frame {
    border-radius: 12px;
    overflow: hidden;
    background: #0d1117;
    border: 1px solid var(--sl-color-gray-5, #2a3f52);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 18px 50px -20px rgba(0, 102, 255, 0.45),
      0 10px 30px -15px rgba(0, 0, 0, 0.6);
  }
  .fe-browser__chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: linear-gradient(180deg, #17334a, #12283a);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .fe-browser__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
    flex: none;
  }
  .fe-browser__dot--r { background: #ff5f56; }
  .fe-browser__dot--y { background: #ffbd2e; }
  .fe-browser__dot--g { background: #27c93f; }
  .fe-browser__addr {
    margin-inline: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    color: #9fb3c8;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 6px;
    padding: 3px 14px;
    max-width: 60%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .fe-browser__frame video {
    display: block;
    width: 100%;
    height: auto;
    background: #0d1117;
  }
  .fe-browser__caption {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--sl-color-gray-3, #8aa0b4);
  }

  @media (max-width: 640px) {
    .fe-consoles__tab {
      font-size: 0.78rem;
      padding: 5px 11px;
    }
    .fe-browser__addr {
      max-width: 70%;
    }
  }
</style>
